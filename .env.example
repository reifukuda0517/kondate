# 献立共有アプリ - Environment Configuration
# Copy this file to .env and run setup_vapid.py to generate VAPID keys

# VAPID Keys for Web Push Notifications (generated by setup_vapid.py)
VAPID_PRIVATE_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_CLAIMS_EMAIL="mailto:your-email@example.com"

# Server Configuration
HOST=0.0.0.0
PORT=8000
